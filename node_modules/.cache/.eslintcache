function Home() {\r\n  return (\r\n    <div>\r\n        <HomeUi></HomeUi>\r\n        \r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Home\r\n","C:\\Users\\ASUS\\Desktop\\hackathon\\src\\pages\\PlanTrip.jsx",["147","148"],[],"C:\\Users\\ASUS\\Desktop\\hackathon\\src\\options\\options.js",[],[],"C:\\Users\\ASUS\\Desktop\\hackathon\\src\\pages\\service\\GeminiAi.jsx",["149","150"],[],"const {\r\n    GoogleGenerativeAI,\r\n    HarmCategory,\r\n    HarmBlockThreshold,\r\n  } = require(\"@google/generative-ai\");\r\n  \r\n  const apiKey = process.env.GEMINI_API_KEY;\r\n  console.log(apiKey)\r\n  const genAI = new GoogleGenerativeAI(\"AIzaSyC1LpXEK7OL1hy0pVWnYKUN3_8baXMXZC8\");\r\n  \r\n  const model = genAI.getGenerativeModel({\r\n    model: \"gemini-2.0-flash\",\r\n  });\r\n  \r\n  const generationConfig = {\r\n    temperature: 1,\r\n    topP: 0.95,\r\n    topK: 40,\r\n    maxOutputTokens: 8192,\r\n    responseMimeType: \"application/json\",\r\n  };\r\n  \r\n  \r\n   export const chatSession = model.startChat({\r\n      generationConfig,\r\n      history: [\r\n        {\r\n          role: \"user\",\r\n          parts: [\r\n            {text: \"Generate travel plan for location: las vegas , for 3 days  for a couple , moderate budget  and give me hotels option list with hotel names , hotel  address , price , rating , hotel image url , Geo coordinates , description  and suggest itinerary with place Name , place , details , rating , place image url , Geo coordinates  , ticket pricing , time to travel  each location for 3 days with each plan with best time to visit and also mode of travel to choose that sort according to budget and time duration for user  in JSON formate \"},\r\n          ],\r\n        },\r\n        {\r\n          role: \"model\",\r\n          parts: [\r\n            {text: \"Okay, here's a JSON format travel plan for a 3-day Las Vegas trip for a couple on a moderate budget, including hotel options and a detailed itinerary.  I've focused on balancing iconic Vegas experiences with budget-friendly choices.\\n\\n```json\\n{\\n  \\\"trip_name\\\": \\\"Las Vegas Getaway for Two\\\",\\n  \\\"duration\\\": \\\"3 Days\\\",\\n  \\\"budget\\\": \\\"Moderate\\\",\\n  \\\"travelers\\\": \\\"Couple\\\",\\n  \\\"location\\\": \\\"Las Vegas, Nevada\\\",\\n\\n  \\\"hotel_options\\\": [\\n    {\\n      \\\"hotel_name\\\": \\\"Park MGM Las Vegas\\\",\\n      \\\"hotel_address\\\": \\\"3770 S Las Vegas Blvd, Las Vegas, NV 89109\\\",\\n      \\\"price_range\\\": \\\"$150 - $300 per night\\\",\\n      \\\"rating\\\": 4.5,\\n      \\\"hotel_image_url\\\": \\\"https://example.com/parkmgm_image.jpg\\\",\\n      \\\"geo_coordinates\\\": {\\n        \\\"latitude\\\": 36.1128,\\n        \\\"longitude\\\": -115.1725\\n      },\\n      \\\"description\\\": \\\"Smoke-free hotel on the Strip with a relaxed atmosphere, great restaurants, and easy access to T-Mobile Arena. Includes free wifi. Nice pool area.\\\",\\n      \\\"amenities\\\": [\\\"Pool\\\", \\\"Restaurants\\\", \\\"Casino\\\", \\\"Fitness Center\\\", \\\"Free WiFi\\\"]\\n    },\\n    {\\n      \\\"hotel_name\\\": \\\"The LINQ Hotel + Experience\\\",\\n      \\\"hotel_address\\\": \\\"3535 S Las Vegas Blvd, Las Vegas, NV 89109\\\",\\n      \\\"price_range\\\": \\\"$100 - $250 per night\\\",\\n      \\\"rating\\\": 4.0,\\n      \\\"hotel_image_url\\\": \\\"https://example.com/linq_image.jpg\\\",\\n      \\\"geo_coordinates\\\": {\\n        \\\"latitude\\\": 36.1172,\\n        \\\"longitude\\\": -115.1693\\n      },\\n      \\\"description\\\": \\\"Located in the heart of the Strip, The LINQ offers modern rooms and access to the High Roller observation wheel and The LINQ Promenade. Good value for its location.\\\",\\n      \\\"amenities\\\": [\\\"Pool\\\", \\\"Restaurants\\\", \\\"Casino\\\", \\\"Shopping\\\", \\\"High Roller Access\\\"]\\n    },\\n    {\\n      \\\"hotel_name\\\": \\\"Flamingo Las Vegas\\\",\\n      \\\"hotel_address\\\": \\\"3555 S Las Vegas Blvd, Las Vegas, NV 89109\\\",\\n      \\\"price_range\\\": \\\"$80 - $200 per night\\\",\\n      \\\"rating\\\": 3.8,\\n      \\\"hotel_image_url\\\": \\\"https://example.com/flamingo_image.jpg\\\",\\n      \\\"geo_coordinates\\\": {\\n        \\\"latitude\\\": 36.1165,\\n        \\\"longitude\\\": -115.1751\\n      },\\n      \\\"description\\\": \\\"An iconic hotel with a classic Vegas vibe, known for its wildlife habitat with flamingos and a central Strip location.  Rooms can be a bit dated, but the price is right.\\\",\\n      \\\"amenities\\\": [\\\"Pool\\\", \\\"Restaurants\\\", \\\"Casino\\\", \\\"Wildlife Habitat\\\"]\\n    }\\n  ],\\n\\n  \\\"itinerary\\\": {\\n    \\\"day_1\\\": {\\n      \\\"theme\\\": \\\"Strip Exploration & High Roller Views\\\",\\n      \\\"activities\\\": [\\n        {\\n          \\\"place_name\\\": \\\"Welcome to Las Vegas Sign\\\",\\n          \\\"place\\\": \\\"South Las Vegas Boulevard\\\",\\n          \\\"details\\\": \\\"Take a photo at the iconic Welcome to Las Vegas sign. Be prepared to wait in line.\\\",\\n          \\\"rating\\\": 4.5,\\n          \\\"place_image_url\\\": \\\"https://example.com/vegas_sign_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.0826,\\n            \\\"longitude\\\": -115.1732\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free\\\",\\n          \\\"time_to_travel\\\": \\\"15 minutes from the Strip by car/taxi/ride-share.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Early morning to avoid crowds and heat.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Bellagio Conservatory & Botanical Garden\\\",\\n          \\\"place\\\": \\\"Bellagio Hotel\\\",\\n          \\\"details\\\": \\\"Visit the stunning botanical displays at the Bellagio Conservatory. The displays change seasonally.\\\",\\n          \\\"rating\\\": 5.0,\\n          \\\"place_image_url\\\": \\\"https://example.com/bellagio_conservatory_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1126,\\n            \\\"longitude\\\": -115.1764\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free\\\",\\n          \\\"time_to_travel\\\": \\\"Walking distance on the Strip.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Anytime, but can be crowded during peak hours.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Bellagio Fountains\\\",\\n          \\\"place\\\": \\\"Bellagio Hotel\\\",\\n          \\\"details\\\": \\\"Watch the spectacular Bellagio fountain show. Shows run frequently in the afternoon and evening.\\\",\\n          \\\"rating\\\": 5.0,\\n          \\\"place_image_url\\\": \\\"https://example.com/bellagio_fountains_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1127,\\n            \\\"longitude\\\": -115.1761\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free\\\",\\n          \\\"time_to_travel\\\": \\\"Walking distance on the Strip.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Evening for the full light show experience. Check show times in advance.\\\",\\n           \\\"show_times\\\": \\\"Typically every 30 minutes in the afternoon and every 15 minutes in the evening.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"High Roller Observation Wheel\\\",\\n          \\\"place\\\": \\\"The LINQ Promenade\\\",\\n          \\\"details\\\": \\\"Take a ride on the High Roller for panoramic views of Las Vegas.\\\",\\n          \\\"rating\\\": 4.5,\\n          \\\"place_image_url\\\": \\\"https://example.com/high_roller_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1166,\\n            \\\"longitude\\\": -115.1690\\n          },\\n          \\\"ticket_pricing\\\": \\\"$25 - $37 per person (depending on time of day)\\\",\\n          \\\"time_to_travel\\\": \\\"Located on the LINQ Promenade.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Sunset for the best views. Purchase tickets online in advance to save time.\\\"\\n        },\\n         {\\n          \\\"place_name\\\": \\\"In-N-Out Burger (Dinner)\\\",\\n          \\\"place\\\": \\\"Multiple locations, including near the LINQ\\\",\\n          \\\"details\\\": \\\"Enjoy a classic In-N-Out Burger. A budget-friendly and iconic West Coast experience.\\\",\\n          \\\"rating\\\": 4.7,\\n          \\\"place_image_url\\\": \\\"https://example.com/innout_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1172,\\n            \\\"longitude\\\": -115.1688\\n          },\\n          \\\"ticket_pricing\\\": \\\"$10-15 per person\\\",\\n          \\\"time_to_travel\\\": \\\"Walking distance from the Linq High Roller\\\",\\n          \\\"best_time_to_visit\\\": \\\"Evening\\\"\\n        }\\n      ]\\n    },\\n    \\\"day_2\\\": {\\n      \\\"theme\\\": \\\"Downtown Vegas & Thrill Rides\\\",\\n      \\\"activities\\\": [\\n        {\\n          \\\"place_name\\\": \\\"Fremont Street Experience\\\",\\n          \\\"place\\\": \\\"Downtown Las Vegas\\\",\\n          \\\"details\\\": \\\"Experience the Viva Vision light show on Fremont Street. Explore the casinos and attractions in downtown Las Vegas.\\\",\\n          \\\"rating\\\": 4.2,\\n          \\\"place_image_url\\\": \\\"https://example.com/fremont_street_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1701,\\n            \\\"longitude\\\": -115.1420\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free (for the Fremont Street Experience itself; attractions and gambling cost extra)\\\",\\n          \\\"time_to_travel\\\": \\\"20-30 minutes from the Strip by car/taxi/ride-share.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Evening for the full light show experience. Shows run hourly.\\\",\\n          \\\"show_times\\\": \\\"Typically hourly in the evening. Check the schedule online.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"SlotZilla Zip Line\\\",\\n          \\\"place\\\": \\\"Fremont Street Experience\\\",\\n          \\\"details\\\": \\\"Ride the SlotZilla zip line for a thrilling experience over Fremont Street.\\\",\\n          \\\"rating\\\": 4.0,\\n          \\\"place_image_url\\\": \\\"https://example.com/slotzilla_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1702,\\n            \\\"longitude\\\": -115.1418\\n          },\\n          \\\"ticket_pricing\\\": \\\"$39 - $59 per person (depending on the zip line and time of day)\\\",\\n          \\\"time_to_travel\\\": \\\"Located on Fremont Street.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Daytime or evening. Book tickets in advance, especially during peak season.\\\"\\n        },\\n          {\\n          \\\"place_name\\\": \\\"Heart Attack Grill\\\",\\n          \\\"place\\\": \\\"Downtown Las Vegas\\\",\\n          \\\"details\\\": \\\"Dine at the Heart Attack Grill for a novelty food experience.\\\",\\n          \\\"rating\\\": 3.5,\\n          \\\"place_image_url\\\": \\\"https://example.com/heartattack_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1702,\\n            \\\"longitude\\\": -115.1419\\n          },\\n          \\\"ticket_pricing\\\": \\\"$20-30 per person\\\",\\n          \\\"time_to_travel\\\": \\\"Located on Fremont Street.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Daytime or evening.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Gold and Silver Pawn Shop (Pawn Stars)\\\",\\n          \\\"place\\\": \\\"713 S Las Vegas Blvd, Las Vegas, NV 89101\\\",\\n          \\\"details\\\": \\\"Visit the famous pawn shop featured on the TV show Pawn Stars.\\\",\\n          \\\"rating\\\": 3.8,\\n          \\\"place_image_url\\\": \\\"https://example.com/pawn_stars_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1614,\\n            \\\"longitude\\\": -115.1479\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free (but expect to potentially buy something!)\\\",\\n          \\\"time_to_travel\\\": \\\"5-10 minutes from Fremont Street by car/taxi/ride-share.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Daytime.  Can be crowded.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Optional: Stratosphere Tower\\\",\\n          \\\"place\\\": \\\"2000 S Las Vegas Blvd, Las Vegas, NV 89104\\\",\\n          \\\"details\\\": \\\"If you're feeling adventurous, visit the Stratosphere Tower for thrill rides and views.\\\",\\n          \\\"rating\\\": 4.0,\\n          \\\"place_image_url\\\": \\\"https://example.com/stratosphere_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1468,\\n            \\\"longitude\\\": -115.1557\\n          },\\n          \\\"ticket_pricing\\\": \\\"$25 - $40 for tower admission; additional for rides.\\\",\\n          \\\"time_to_travel\\\": \\\"5-10 minutes from Fremont Street by car/taxi/ride-share.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Evening for the city views. Be prepared for a potentially long wait for rides.\\\"\\n        }\\n      ]\\n    },\\n    \\\"day_3\\\": {\\n      \\\"theme\\\": \\\"Relaxation & Departure\\\",\\n      \\\"activities\\\": [\\n        {\\n          \\\"place_name\\\": \\\"Pool Time\\\",\\n          \\\"place\\\": \\\"Your Hotel\\\",\\n          \\\"details\\\": \\\"Relax by the pool at your hotel.\\\",\\n          \\\"rating\\\": 4.5,\\n          \\\"place_image_url\\\": \\\"https://example.com/hotel_pool_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": \\\"Depends on hotel\\\",\\n            \\\"longitude\\\": \\\"Depends on hotel\\\"\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free (included with your hotel stay)\\\",\\n          \\\"time_to_travel\\\": \\\"At your hotel.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Morning or afternoon to avoid the hottest part of the day.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Mirage Volcano\\\",\\n          \\\"place\\\": \\\"The Mirage Hotel\\\",\\n          \\\"details\\\": \\\"Watch the Mirage Volcano erupt. Shows run nightly.\\\",\\n          \\\"rating\\\": 4.7,\\n          \\\"place_image_url\\\": \\\"https://example.com/mirage_volcano_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1212,\\n            \\\"longitude\\\": -115.1754\\n          },\\n          \\\"ticket_pricing\\\": \\\"Free\\\",\\n          \\\"time_to_travel\\\": \\\"Walking distance on the Strip.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Nighttime. Shows run several times per night. Check the schedule online.\\\"\\n        },\\n         {\\n          \\\"place_name\\\": \\\"Secret Garden and Dolphin Habitat\\\",\\n          \\\"place\\\": \\\"The Mirage Hotel\\\",\\n          \\\"details\\\": \\\"Visit the Secret Garden and Dolphin Habitat\\\",\\n          \\\"rating\\\": 4.7,\\n          \\\"place_image_url\\\": \\\"https://example.com/mirage_dolphin.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.1212,\\n            \\\"longitude\\\": -115.1754\\n          },\\n          \\\"ticket_pricing\\\": \\\"$25-30 per person\\\",\\n          \\\"time_to_travel\\\": \\\"Walking distance on the Strip.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Daytime.\\\"\\n        },\\n        {\\n          \\\"place_name\\\": \\\"Departure\\\",\\n          \\\"place\\\": \\\"McCarran International Airport (LAS)\\\",\\n          \\\"details\\\": \\\"Head to the airport for your departure.\\\",\\n          \\\"rating\\\": \\\"N/A\\\",\\n          \\\"place_image_url\\\": \\\"https://example.com/airport_image.jpg\\\",\\n          \\\"geo_coordinates\\\": {\\n            \\\"latitude\\\": 36.0801,\\n            \\\"longitude\\\": -115.1523\\n          },\\n          \\\"ticket_pricing\\\": \\\"N/A\\\",\\n          \\\"time_to_travel\\\": \\\"10-15 minutes from the Strip by car/taxi/ride-share.\\\",\\n          \\\"best_time_to_visit\\\": \\\"Allow ample time before your flight.\\\"\\n        }\\n      ]\\n    }\\n  },\\n  \\\"notes\\\": [\\n    \\\"This itinerary is a suggestion and can be customized to your preferences.\\\",\\n    \\\"Prices are estimates and may vary depending on the season and availability.\\\",\\n    \\\"Consider purchasing a Las Vegas discount card for savings on attractions.\\\",\\n    \\\"Stay hydrated, especially during the hot summer months.\\\",\\n    \\\"Wear comfortable shoes, as you will be doing a lot of walking.\\\",\\n    \\\"Book shows and tours in advance, especially during peak season.\\\",\\n    \\\"Take advantage of free attractions like the Bellagio fountains and conservatory.\\\",\\n    \\\"Utilize ride-sharing services or public transportation to save on transportation costs.\\\",\\n    \\\"Factor in travel time between locations when planning your day.\\\"\\n  ]\\n}\\n```\\n\\n**Important Considerations:**\\n\\n*   **Image URLs:** Replace the placeholder image URLs (`https://example.com/...`) with actual URLs to images of the hotels and attractions.\\n*   **Pricing:**  Hotel and attraction prices are estimates.  Check current prices before booking.  They fluctuate greatly based on season, day of the week, and events.\\n*   **Transportation:** This plan assumes you'll use a mix of walking, ride-sharing (Uber/Lyft), and possibly taxis.  Consider the cost of transportation when budgeting. The Las Vegas Monorail is an option, but it doesn't stop at all the key locations.\\n*   **Flexibility:** Vegas is a place where plans can easily change.  Be flexible and ready to adjust your itinerary as needed.\\n*   **Show Tickets:** If you want to see a specific show, book tickets well in advance.  Consider looking for last-minute deals, but don't rely on them.\\n*   **Food:**  I've included some budget-friendly options, but Vegas can be expensive for food.  Look for happy hour deals, buffets (if that's your thing), and off-Strip restaurants for more affordable meals.\\n*   **Hotel Location:**  Consider the location of your hotel carefully.  Being centrally located on the Strip can save you time and money on transportation.\\n\\nThis comprehensive JSON provides a solid framework for your Las Vegas trip planning. Remember to tailor it to your specific interests and budget for the best possible experience.\\n\"},\r\n          ],\r\n        },\r\n      ],\r\n    });\r\n","C:\\Users\\ASUS\\Desktop\\hackathon\\src\\Context\\AppContext.js",["151","152"],[],"import { createContext, useEffect, useState } from \"react\";\r\nimport { useNavigate } from \"react-router-dom\";\r\n\r\nexport const AppContext = createContext();\r\n\r\nexport default function  AppContextProvider({children}){\r\n    const [loading , setLoading] = useState(false);\r\n    // const [posts, setPosts]= useState([]);\r\n    // const [page, setPage]= useState(1);\r\n    // const [totalPages, setTotlePages]=  useState(null);\r\n    // const navigate = useNavigate();\r\n    \r\n    //Data Filling pending \r\n    // async function fetchBlogPosts( page =1, tag=null , category) {\r\n    //   setLoading(true);\r\n      \r\n    //   let url = `${baseUrl}?page=${page}`;\r\n    //    if(tag){\r\n    //      url += `&tag=${tag}`;\r\n    //    }\r\n    //    if(category){\r\n    //      url+= `&category=${category}`;\r\n    //    }\r\n \r\n    //   try{\r\n    //     const result = await fetch(url);\r\n    //     const data = await result.json();\r\n    //     console.log(data);\r\n    //     setPage(data.page);\r\n    //     setPosts(data.posts);\r\n    //     setTotlePages(data.totalPages);\r\n \r\n    //   }\r\n    //    catch(error){\r\n    //        toast.error(\"failed to get response\")\r\n    //        setPage(1);\r\n    //        setPosts([]);\r\n    //        setTotlePages(null);\r\n \r\n    //    }\r\n    //    setLoading(false);\r\n     \r\n    // }\r\n \r\n//     const handlePa